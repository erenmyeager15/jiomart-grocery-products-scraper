{
  "actorSpecification": 1,
  "name": "jiomart-grocery-products-scraper",
  "title": "JioMart Product Scraper: Prices & Stock",
  "description": "Scrape public JioMart location-specific grocery and product listings for titles, brands, pack sizes, prices, MRP, discounts, categories, stock status, images, and URLs.",
  "version": "1.0",
  "buildTag": "latest",
  "dockerfile": "Dockerfile",
  "input": "../INPUT_SCHEMA.json",
  "readme": "../README.md",
  "exampleRunInput": {
    "body": "{\"searchQueries\":[\"rice\"],\"locationName\":\"Mumbai\",\"latitude\":19.076,\"longitude\":72.8777,\"brands\":[],\"categories\":[],\"inStockOnly\":true,\"minPrice\":0,\"maxPrice\":1000000,\"maxResults\":1,\"maxPagesPerQuery\":1,\"proxyConfiguration\":{\"useApifyProxy\":true,\"apifyProxyGroups\":[\"RESIDENTIAL\"],\"apifyProxyCountry\":\"IN\"}}",
    "contentType": "application/json; charset=utf-8"
  },
  "output": "./output_schema.json",
  "categories": ["ECOMMERCE", "AUTOMATION"],
  "categoriesVersion": "1.0.0",
  "pricingInfo": {
    "pricingModel": "PAY_PER_EVENT",
    "pricingPerEvent": {
      "actorChargeEvents": {
        "apify-actor-start": {
          "eventTitle": "Actor Start",
          "eventDescription": "Charged when the Actor starts running. Number of events charged depends on Actor memory (one event per GB, minimum one event).",
          "eventPriceUsd": 0.001,
          "isPrimaryEvent": false,
          "isOneTimeEvent": true
        },
        "product-scraped": {
          "eventTitle": "Product scraped",
          "eventDescription": "Charged once for each clean JioMart product saved to the dataset.",
          "eventPriceUsd": 0.003,
          "isPrimaryEvent": true,
          "isOneTimeEvent": false
        }
      }
    }
  },
  "storages": {
    "dataset": "./dataset_schema.json"
  },
  "defaultRunOptions": {
    "build": "latest",
    "memoryMbytes": 2048,
    "timeoutSecs": 1200
  },
  "minMemoryMbytes": 2048,
  "maxMemoryMbytes": 4096
}
